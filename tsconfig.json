{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@hooks": ["./src/hooks"],
      "@hooks/*": ["./src/hooks/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"],
      "@services": ["./src/services"],
      "@services/*": ["./src/services/*"],
      "@constants": ["./src/constants"],
      "@constants/*": ["./src/constants/*"],
      "@types": ["./src/types"],
      "@types/*": ["./src/types/*"],
      "@features": ["./src/features"],
      "@features/*": ["./src/features/*"],
      "@pages": ["./src/pages"],
      "@pages/*": ["./src/pages/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
